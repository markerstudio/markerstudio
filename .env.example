# Marker Studio — environment variables
# Copy to .env.local for local dev, and set these in Vercel → Project → Settings → Environment Variables.
#
# Without DATABASE_URL the site runs fine on seed data and the admin is inert.

# Neon / Vercel Postgres pooled connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Secret for signing admin session cookies (use a long random string)
#   generate: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# One-time secret required to call POST /api/setup (then you can remove it)
SETUP_SECRET="change-me-too"

# Notion internal integration token — enables "Pull from Notion" in the admin.
#   Create at https://www.notion.com/my-integrations, then share each client's
#   database with the integration. Optional; only needed for Notion sync.
NOTION_TOKEN="ntn_..."

# Optional: the Notion "Sources" (Budget Tracker) database ID that holds the
# per-client "Money Left" formula. Defaults to the studio's known database.
NOTION_SOURCES_DB=""

# Meta (Facebook + Instagram) live data. Per-client Page/Instagram/Ad-account
# IDs and a long-lived Page access token are pasted in the admin (stored in the
# client_meta table) — not here. This only overrides the Graph API version.
META_GRAPH_VERSION="v21.0"
