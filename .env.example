# Marker Studio — environment variables
# Copy to .env.local for local dev, and set these in Vercel → Project → Settings → Environment Variables.
#
# Without DATABASE_URL the site runs fine on seed data and the admin is inert.

# Neon / Vercel Postgres pooled connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Secret for signing admin session cookies (use a long random string)
#   generate: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# One-time secret required to call POST /api/setup (then you can remove it)
SETUP_SECRET="change-me-too"

# Roles are email-based (no schema migration needed). All optional — sensible
# defaults are baked in. Comma-separate to list more than one address.
#   SUPERADMIN_EMAIL   — the studio owner; only account that can add/remove admins.
#   PARTNER_EMAILS     — partner accounts (e.g. Ramzi), walled into their own area.
#   PHOTOGRAPHER_EMAILS— photographer accounts (e.g. Ameer), confined to the
#                        photographer portal; that portal is visible to all admins.
SUPERADMIN_EMAIL="elias@marker.ps"
PARTNER_EMAILS="ramzi@marker.ps"
PHOTOGRAPHER_EMAILS="ameer@marker.ps"

# Notion internal integration token — enables "Pull from Notion" in the admin.
#   Create at https://www.notion.com/my-integrations, then share each client's
#   database with the integration. Optional; only needed for Notion sync.
NOTION_TOKEN="ntn_..."

# Optional: the Notion "Sources" (Budget Tracker) database ID that holds the
# per-client "Money Left" formula. Defaults to the studio's known database.
NOTION_SOURCES_DB=""

# Meta (Facebook + Instagram) live data.
#   META_APP_ID / META_APP_SECRET enable one-click "Continue with Facebook" in
#   the admin (create an app at developers.facebook.com, add the "Facebook
#   Login" product, and register <your-site>/api/meta/callback as a valid OAuth
#   redirect URI). Without them you can still connect by pasting IDs + a token.
META_APP_ID=""
META_APP_SECRET=""
# Optional: force the OAuth redirect URI (defaults to <origin>/api/meta/callback).
META_REDIRECT_URI=""
# Optional: override the Graph API version.
META_GRAPH_VERSION="v21.0"

# Anthropic API key — powers the "AI reading" on each client's Analysis tab
# (Claude generates a bilingual strategic analysis from the portal's data).
#   Create at https://console.anthropic.com/. Optional; the button is inert without it.
ANTHROPIC_API_KEY="sk-ant-..."

# Vercel Blob storage — REQUIRED for file uploads (client logos + the Documents
# tab). Without it every upload fails with "File storage isn’t configured".
#   Create a Blob store in Vercel → Storage, then copy its read-write token.
#   (On Vercel it's provisioned automatically when you add a Blob store.)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Web Push (the Notify panel + scheduled reminders). Optional; without them push
# degrades gracefully.
#   generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:hello@marker.ps"

# Secret guarding the scheduled reminder job (Vercel Cron → /api/cron/reminders,
# every 15 min per vercel.json). Vercel automatically sends this as a Bearer
# token on cron runs; set the same value here and in Vercel's env. This is what
# makes due-task reminders reach your phone with the app closed — without VAPID
# keys + this, nothing is pushed proactively.
#   generate: openssl rand -base64 32
CRON_SECRET="change-me-to-a-long-random-string"
