# Marker Studio — environment variables
# Copy to .env.local for local dev, and set these in Vercel → Project → Settings → Environment Variables.
#
# Without DATABASE_URL the site runs fine on seed data and the admin is inert.

# Neon / Vercel Postgres pooled connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Secret for signing admin session cookies (use a long random string)
#   generate: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# One-time secret required to call POST /api/setup (then you can remove it)
SETUP_SECRET="change-me-too"
