{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Marker Admin",
  "version": "0.1.0",
  "identifier": "ps.marker.admin",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Marker Admin",
        "url": "https://marker.ps/admin",
        "width": 1280,
        "height": 832,
        "minWidth": 960,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "category": "Business",
    "shortDescription": "Marker Studio admin portal",
    "longDescription": "Native desktop wrapper for the Marker Studio admin portal at https://marker.ps/admin.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
