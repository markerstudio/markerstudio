{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Marker Studio",
  "version": "0.5.0",
  "identifier": "ps.marker.studio",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "category": "Business",
    "shortDescription": "Marker Studio",
    "longDescription": "Native desktop app for Marker Studio — sign in to the studio admin or your client portal at https://marker.ps/login.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
